[init]
	defaultBranch = main
[user]
    name = kegpoison
	email = ugglefluffie@gmail.com
[gpg]
	format = ssh
[gpg "ssh"]
    allowedSignersFile = ~/.config/git/allowed_signers
[commit]
    gpgsign = true
[core]
    editor = vim
    autocrlf = input
    ignorecase = false
[push]
    autoSetupRemote = true
    default = simple
[pull]
    rebase = true
[rebase]
    autoStash = true
[merge]
    conflictstyle = zdiff3
	tool = vimdiff
[diff]
    colorMoved = zebra
[rerere]
    enabled = true
    autoupdate = true
[alias]
    st = status
    co = checkout
    br = branch
    cm = commit
    lg = log --graph --decorate --oneline --all --format='%h %G? %s'
    last = log -1 HEAD
    unstage = reset HEAD --
[fetch]
    prune = true
[status]
    branch = true
[bash]
    showInformativeStatus = true

[include]
    path = .gitconfig.local
