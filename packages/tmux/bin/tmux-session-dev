#!/usr/bin/env bash
set -euo pipefail

SESSION="dev"
VIM_WIDTH=60 # Must not be below 0 or above 100!
DELAY='0.4'

if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux attach-session -t "$SESSION"
    exit 0
fi

tmux new-session -d -s "$SESSION" -n editor

tmux new-window -t "$SESSION" -n shell

tmux select-window -t "$SESSION:1"

tmux split-window -h -p $((100 - VIM_WIDTH)) -t "$SESSION:editor.1"

tmux split-window -v -t "$SESSION:editor.2"

tmux send-keys -t "$SESSION:editor.1" "vim ." C-m
tmux send-keys -t "$SESSION:editor.2" "sleep $DELAY && cmatrix -s" C-m
tmux send-keys -t "$SESSION:editor.3" "sleep $DELAY && cbonsai -S -W 3 -t 0.02" C-m

tmux select-pane -t "$SESSION:editor.1"

tmux attach-session -t "$SESSION"
